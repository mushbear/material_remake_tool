{
  "experiment_a": {
    "name": "字幕处理方案对比",
    "description": "对比纯AI API方案与LaMa方案的效果和成本",
    "enabled": true,
    "methods": {
      "pure_ai_api": {
        "name": "纯AI API方案",
        "enabled": true,
        "provider": "volcano",
        "features": {
          "subtitle_detection": true,
          "subtitle_removal": true,
          "speech_recognition": true,
          "translation": true,
          "subtitle_generation": true
        }
      },
      "lama_local": {
        "name": "LaMa本地方案",
        "enabled": false,
        "tools": {
          "ocr_engine": "PaddleOCR",
          "inpainting_model": "LaMa",
          "speech_recognition": "OpenAI Whisper",
          "translation": "Qwen API"
        }
      }
    },
    "test_materials": [
      "1337589",
      "1330603",
      "1330602",
      "1329504",
      "1330869"
    ],
    "metrics": [
      "processing_time",
      "video_quality",
      "subtitle_removal_quality",
      "translation_accuracy",
      "api_cost",
      "implementation_complexity"
    ],
    "output_dir": "./data/output/experiment_a"
  },
  "experiment_b": {
    "name": "转场方法对比",
    "description": "对比AI驱动转场与规则引擎的效果",
    "enabled": true,
    "methods": {
      "ai_driven": {
        "name": "AI驱动转场",
        "enabled": true,
        "provider": "volcano",
        "features": {
          "scene_feature_extraction": true,
          "emotion_analysis": true,
          "transition_recommendation": true,
          "coherence_scoring": true
        }
      },
      "rule_based": {
        "name": "规则引擎",
        "enabled": true,
        "rule_file": "./config/transition_rules.json"
      }
    },
    "test_schemes": [
      "方案1",
      "方案2"
    ],
    "metrics": [
      "transition_naturalness",
      "narrative_coherence",
      "processing_time",
      "user_satisfaction",
      "api_cost"
    ],
    "evaluation_method": "user_rating",
    "output_dir": "./data/output/experiment_b"
  },
  "general_settings": {
    "data_dir": "./data",
    "temp_dir": "./data/temp",
    "output_base_dir": "./data/output",
    "json_source_dir": "/Users/wangchenyi/video_ad_analyzer/test_20260311/output",
    "log_level": "INFO",
    "save_intermediate_results": true,
    "parallel_processing": true,
    "max_workers": 4
  },
  "transition_rules": {
    "scene_jump": {
      "transition": "fade",
      "duration": 1.0,
      "description": "场景跳转时使用淡入淡出"
    },
    "time_jump": {
      "transition": "flash",
      "duration": 0.5,
      "description": "时间跳跃（闪回）时使用闪白转场"
    },
    "emotion_sudden_change": {
      "E07-高甜 → E03-施压": {
        "transition": "cut",
        "duration": 0
      },
      "E03-施压 → E05-反击": {
        "transition": "cut",
        "duration": 0
      }
    },
    "same_scene": {
      "transition": "dissolve",
      "duration": 1.5,
      "description": "同场景使用溶解过渡"
    },
    "emotion_gradual": {
      "transition": "fade",
      "duration": 2.0,
      "description": "情绪渐进使用淡入淡出"
    }
  }
}
